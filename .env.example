# ==========================================================
# PostgreSQL
# ==========================================================
POSTGRES_USER=integrity_user
POSTGRES_PASS=ALTERAR_SENHA_FORTE
POSTGRES_DB=integrity_sul

# DATABASE_URL é montada pelo docker-compose a partir das variáveis acima.
# Para rodar o backend FORA do Docker (dev local), descomente e ajuste:
# DATABASE_URL=postgresql://integrity_user:ALTERAR_SENHA_FORTE@localhost:5432/integrity_sul?schema=public

# ==========================================================
# Redis
# ==========================================================
# REDIS_URL=redis://localhost:6379   # (apenas para rodar backend fora do Docker)

# ==========================================================
# JWT (gerar com: openssl rand -base64 64)
# ==========================================================
JWT_SECRET=GERAR_COM_openssl_rand_-base64_64
JWT_REFRESH_SECRET=GERAR_COM_openssl_rand_-base64_64

# ==========================================================
# Garage (preencher após rodar garage/init-garage.sh)
# ==========================================================
GARAGE_ACCESS_KEY=
GARAGE_SECRET_KEY=
# GARAGE_ENDPOINT=http://localhost:3900   # (apenas para rodar backend fora do Docker)

# ==========================================================
# Resend (e-mail transacional)
# ==========================================================
RESEND_API_KEY=

# ==========================================================
# WhatsApp Cloud API (Meta)
# ==========================================================
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ==========================================================
# Google Calendar API
# ==========================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==========================================================
# Backup offsite
# ==========================================================
BACKUP_REMOTE_USER=
BACKUP_REMOTE_HOST=
BACKUP_REMOTE_PATH=/backups/integrity

# ==========================================================
# App
# ==========================================================
APP_URL=https://app.integritysul.com.br
NEXT_PUBLIC_API_URL=https://api.integritysul.com.br
